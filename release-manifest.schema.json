{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/omkhar/resetusb/blob/main/release-manifest.schema.json",
  "title": "resetusb release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "release_tag",
    "source_digest",
    "builder_digest",
    "builder_workflow",
    "reproducible_inputs",
    "primary_artifacts"
  ],
  "properties": {
    "format_version": {
      "const": 2
    },
    "release_tag": {
      "type": "string",
      "pattern": "^v(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "source_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "builder_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "builder_workflow": {
      "type": "string",
      "pattern": "^https://github\\.com/[^/]+/[^/]+/\\.github/workflows/release-builder\\.yml@refs/heads/main$"
    },
    "reproducible_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_date_epoch",
        "builder_base_image",
        "debian_snapshot_url",
        "debian_snapshot_timestamp",
        "debian_suite"
      ],
      "properties": {
        "source_date_epoch": {
          "type": "integer",
          "minimum": 0
        },
        "builder_base_image": {
          "type": "string",
          "minLength": 1
        },
        "debian_snapshot_url": {
          "type": "string",
          "pattern": "^https?://"
        },
        "debian_snapshot_timestamp": {
          "type": "string",
          "pattern": "^[0-9]{8}T[0-9]{6}Z$"
        },
        "debian_suite": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "primary_artifacts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z0-9._-]+$": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sha256"
          ],
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        }
      }
    }
  }
}
